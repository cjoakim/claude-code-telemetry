{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(cat:*)",
      "Bash(cd:*)",
      "Bash(cp:*)",
      "Bash(git:*)",
      "Bash(grep:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(mv:*)",
      "Bash(pylint:*)",
      "Bash(pytest:*)",
      "Bash(python:*)",
      "Bash(ruff:*)",
      "Bash(uv run:*)",
      "Bash(uv:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(sudo:*)"
    ],
    "defaultMode": "default"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cat | jq -c '.' >> ~/.claudex/hooks.jsonl"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cat | jq -c '.' >> ~/.claudex/hooks.jsonl"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cat | jq -c '.' >> ~/.claudex/hooks.jsonl"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "cat | jq -c '.' >> ~/.claudex/hooks.jsonl"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "cat | jq -c '.' >> ~/.claudex/hooks.jsonl"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cat | jq -c '.' >> ~/.claudex/hooks.jsonl"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cat | jq -c '.' >> ~/.claudex/hooks.jsonl"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "INPUT=$(cat); TRANSCRIPT=$(echo \"$INPUT\" | jq -r '.transcript_path'); echo \"$INPUT\" | jq -c '.' >> ~/.claudex/hooks.jsonl; tr -d '\\000-\\010\\013\\014\\016-\\037' < \"$TRANSCRIPT\" | jq -s 'map(select(.type==\"assistant\" and .message.usage != null)) | {turns: length, models: ([.[].message.model] | unique), input_tokens: (map(.message.usage.input_tokens // 0) | add), output_tokens: (map(.message.usage.output_tokens // 0) | add), cache_read_input_tokens: (map(.message.usage.cache_read_input_tokens // 0) | add), cache_creation_input_tokens: (map(.message.usage.cache_creation_input_tokens // 0) | add)}' 2>/dev/null >> ~/.claudex/hooks-tokens.jsonl"
          }
        ]
      }
    ]
  },
  "cleanupPeriodDays": 30,
  "includeCoAuthoredBy": true,
  "respectGitignore": true
}
